<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | MiniStore</title>

    <!-- Fonts/Icons -->
    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,800;0,900;1,600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/glider-js@1/glider.min.css" rel="stylesheet">
    <link rel="stylesheet" href="css/main.css">
    <link rel="stylesheet" href="css/menu.css">
    <link rel="stylesheet" href="css/banner.css">
    <link rel="stylesheet" href="css/Index.css">
    <link rel="stylesheet" href="css/glider.css">
    <link rel="stylesheet" href="css/animate.css">
    <link rel="stylesheet" href="css/menu.css">
    <link rel="stylesheet" href="css/Footer.css">

</head>

<body id='body'>

    <!-- Menu -->
    <nav class="animate-up">
        <a href="/produtos"><button id="menu-btn-1" class="menu-btn">Produtos</button></a>
        <button id="menu-btn-2" class="menu-btn">Coleções</button>
        <div class="div-logo-img"><img src="/images/logo2.png"></div>
        <button id="menu-btn-3" class="menu-btn">Quem Somos</button>
        <button id="menu-btn-4" class="menu-btn">Contato</button>
    </nav>

    <!-- Container Principal -->

    <div id="container">

        <!-- Banner Fast and Furious -->
        <div class="banner-container animate-up">
            <img src="/images/FastFurious.png">

            <a href="/produtos">
                <button id="btn-FastFurious" class="btn-Banner">Ver Coleção</button>
            </a>

        </div>

        <!-- Products Carousel -->
        <div class="products-container">

            <h1> Miniaturas Mais Vendidas </h1>

            <div class="c-carousel__slides js-carousel--responsive animate-up">
                {{#each miniatura}}
                <div class="c-carousel__slide">
                    <div class="product">
                        <a href="/produto?prod_id={{this.prod_id}}">
                            <div class="image_prod">
                                <img src={{this.prod_image}} alt="Image-Name">
                            </div>
                        </a>
                        <div class="product-info">
                            <h3>{{this.prod_name}}</h3>
                            <p>R${{this.prod_price}}</p>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>

            <button id="btn-glider-prev" class="js-carousel--responsive-prev"><i class="fa fa-chevron-left"
                    aria-hidden="true"></i></button>
            <button id="btn-glider-next" class="js-carousel--responsive-next"><i class="fa fa-chevron-right"
                    aria-hidden="true"></i></button>

        </div>

        <!-- Banner MostWanted -->

        <div class="banner-container animate-up">
            <img src="/images/MostWanted.png">
            <a href="/produtos">
                <button id="btn-MostWanted" class="btn-Banner">Obter Edição Limitada</button>
            </a>
        </div>


        <!-- Fast Furious -->
        <div class="products-container">

            <h1> Coleção Velozes e Furiosos </h1>

            <div class="c-carousel__slides js-carousel--responsive2 animate-up">
                {{#each fast}}
                <div class="c-carousel__slide">
                    <div class="product">
                        <div class="image_prod">
                            <img src={{this.prod_image}} alt="Image-Name">
                        </div>
                        <div class="product-info">
                            <h3>{{this.prod_name}}</h3>
                            <p>R${{this.prod_price}}</p>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>

            <button id="btn-glider-prev" class="js-carousel--responsive-prev2"><i class="fa fa-chevron-left"
                    aria-hidden="true"></i></button>
            <button id="btn-glider-next" class="js-carousel--responsive-next2"><i class="fa fa-chevron-right"
                    aria-hidden="true"></i></button>

        </div>

        <!-- Banner Maqueen -->
        <div class="banner-container animate-up">
            <img src="/images/Maquuen.png">
            <a href="/produtos">
                <button id="btn-Maqueen" class="btn-Banner">Ver Commics</button>
            </a>
        </div>

        <!-- Fast Furious -->
        <div class="products-container">

            <h1> Edições Limitadas </h1>

            <div class="c-carousel__slides js-carousel--responsive3 animate-up">
                {{#each fast}}
                <div class="c-carousel__slide">
                    <div class="product">
                        <div class="image_prod">
                            <img src={{this.prod_image}} alt="Image-Name">
                        </div>
                        <div class="product-info">
                            <h3>{{this.prod_name}}</h3>
                            <p>R${{this.prod_price}}</p>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>

            <button id="btn-glider-prev" class="js-carousel--responsive-prev3"><i class="fa fa-chevron-left"
                    aria-hidden="true"></i></button>
            <button id="btn-glider-next" class="js-carousel--responsive-next3"><i class="fa fa-chevron-right"
                    aria-hidden="true"></i></button>
        </div>

        <!-- -->

        <div class="grid-banner">
            <div class="small-banner animate-up">
                <img src="images/Musgle.png" class="small-banner-img">
                <a href="/produtos">
                    <button id="btn-MostWanted" class="btn-Banner">Ver Musgles</button>
                </a>
            </div>

            <div class="small-banner animate-up">
                <img src="images/Exotic.png" class="small-banner-img">
                <a href="/produtos">
                    <button id="btn-Maqueen" class="btn-Banner">Ver Exotics</button>
                </a>
            </div>

            <div class="small-banner animate-up">
                <img src="images/Tuner.png" class="small-banner-img">
                <a href="/produtos">
                    <button id="btn-MostWanted" class="btn-Banner">Ver Tuners</button>
                </a>
            </div>

            <div class="small-banner animate-up">
                <img src="images/Motos.png" class="small-banner-img">
                <a href="/produtos">
                    <button id="btn-Maqueen" class="btn-Banner">Ver Motos</button>
                </a>
            </div>
        </div>

        <!-- footer -->
        <div class="footer animate-up">

            <div class="footer-title">
                <img src="images/logo2.png">
            </div>

            <div class="footer-info">


                <div class="info-content">
                    <h3>Nos siga</h3>
                    <ul>
                        <li>Facebook</li>
                        <li>Twitter</li>
                        <li>Instagram</li>
                        <li>Youtube</li>
                    </ul>
                </div>

                <div class="info-content">
                    <h3>Faça o Download do Nosso App</h3>
                    <p>Disponivel em aparelhos Apple e Android.</p>
                    <div class="store-apps">
                        <img src="images/NavBar/Logoapp.png"> <!-- playstore -->
                    </div>

                </div>

                <div class="info-content">
                    <h3>Links Uteis</h3>
                    <ul>
                        <li>Coupons</li>
                        <li>Blog Post</li>
                        <li>Return Policy</li>
                        <li>Join Affiliate</li>
                    </ul>
                </div>


            </div>

            <hr>
            <p class="copyright">Copyright@2020 - MiniStore</p>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/glider-js@1/glider.min.js"></script>
    <script src="/scripts/glider.js"></script>

</body>

</html>