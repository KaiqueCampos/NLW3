<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Produtos | MiniStore</title>

    <!-- Fonts/Icons -->
    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,800;0,900;1,600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- CSS -->
    <link rel="stylesheet" href="css/main.css">
    <link rel="stylesheet" href="css/banner.css">
    <link rel="stylesheet" href="css/animate.css">
    <link rel="stylesheet" href="css/menu.css">
    <link rel="stylesheet" href="css/produtos.css">
    <link rel="stylesheet" href="css/Footer.css">
    <link rel="stylesheet" href="css/cart.css">




</head>

<body id='body'>


    <!-- Container Principal -->

    <div id="container">

        <div class="cart-container">

            <img class="firstImage" src="{{miniatura.prod_image}}">


            <div class="info">

                <h2 class="name">{{miniatura.prod_name}}</h2>
                <span class="id">{{miniatura.prod_id}}</span>
                <span class="image">{{miniatura.prod_image}}</span>


                <p class="colection">{{miniatura.prod_colection}}</p>
                <p>Cor: Vermelha</p>
                <div class="inline">
                    <p>Quantidade:</p>
                    <button onclick="RemoveOne(event)" class="btn-qnt remove">-</button>
                    <p class="quantidade">1</p>
                    <button onclick="AddOne(event)" class="btn-qnt add">+</button>
                </div>
                <h4 class="prod_price">{{miniatura.prod_price}}</h4>

                <button class="setCart" onclick="addProduct()">Adicionar Produto</button>
            </div>
        </div>

        <div class="inCart">
            <div class="products">
                <!-- Cart Itens here! -->
            </div>
        </div>





        {{!-- <h1 class="id">{{miniatura.prod_id}}</h1>
        <h1 class="prod_price">{{miniatura.prod_price}}</h1>
        <h1 class="quantidade">10</h1>
        <h1 class="total">0</h1> --}}


    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.1/jquery.min.js"></script>
    <script src="scripts/cart.js"></script>
</body>

</html>